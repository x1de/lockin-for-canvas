{
  "manifest_version": 3,
  "name": "LockIn for Canvas",
  "description": "Social accountability layer for Canvas LMS",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "notifications", "alarms"],
  "host_permissions": ["https://*.instructure.com/*"],
  "background": {
    "service_worker": "extension/src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["https://*.instructure.com/*"],
    "js": ["extension/src/content/index.tsx"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "extension/src/popup/index.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  }
}
